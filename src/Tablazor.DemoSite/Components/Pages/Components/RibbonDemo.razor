@page "/components/ribbon"
@rendermode InteractiveServer
@using Tablazor.Icons

<PageTitle>Ribbon - Tablazor</PageTitle>

<div class="page-header mb-4">
    <h1 class="page-title">Ribbon</h1>
    <p class="text-muted">
        Ribbons are decorative labels that attach to a corner or edge of a card or container to highlight featured, new, or promoted content.
        The parent container must have <code>position-relative</code> applied.
    </p>
</div>

<ComponentDemo
    Id="basic-ribbon"
    Title="Basic Ribbon"
    Description="A simple ribbon with a color and text label placed in the top-right corner by default."
    SourceCode="@_basicRibbonCode">
    <div class="card position-relative" style="min-height: 80px;">
        <TabRibbon Color="TabColors.Primary">NEW</TabRibbon>
        <div class="card-body">
            <p class="text-muted mb-0">Card with a ribbon in the top-right corner.</p>
        </div>
    </div>
</ComponentDemo>

