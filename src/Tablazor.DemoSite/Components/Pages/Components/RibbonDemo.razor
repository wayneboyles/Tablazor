<ComponentDemo
    Id="ribbon-bookmark"
    Title="Bookmark Ribbon"
    Description="The Bookmark variant adds a triangular notch to the bottom of the ribbon, giving it a classic bookmark shape."
    SourceCode="@_ribbonBookmarkCode">
    <div class="row row-cards">
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative" style="min-height: 100px;">
                <TabRibbon Color="TabColors.Primary" Bookmark="true">NEW</TabRibbon>
                <div class="card-body">
                    <p class="text-muted small mb-0">Bookmark ribbon, top-right</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative" style="min-height: 100px;">
                <TabRibbon Color="TabColors.Success" Position="RibbonPosition.TopStart" Bookmark="true">SALE</TabRibbon>
                <div class="card-body">
                    <p class="text-muted small mb-0">Bookmark ribbon, top-left</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative" style="min-height: 100px;">
                <TabRibbon Color="TabColors.Danger" Position="RibbonPosition.TopEnd" Bookmark="true">HOT</TabRibbon>
                <div class="card-body">
                    <p class="text-muted small mb-0">Bookmark ribbon, danger color</p>
                </div>
            </div>
        </div>
    </div>
</ComponentDemo>

<ComponentDemo
    Id="ribbon-icon"
    Title="Ribbon with Icon"
    Description="Ribbons can display a Tabler icon using the Icon parameter instead of (or alongside) text content."
    SourceCode="@_ribbonIconCode">
    <div class="row row-cards">
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative" style="min-height: 80px;">
                <TabRibbon Color="TabColors.Yellow" Icon="@TabIcons.Filled.Star" />
                <div class="card-body">
                    <p class="text-muted small mb-0">Star icon ribbon</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative" style="min-height: 80px;">
                <TabRibbon Color="TabColors.Red" Position="RibbonPosition.TopStart" Icon="@TabIcons.Filled.Flame" />
                <div class="card-body">
                    <p class="text-muted small mb-0">Flame icon ribbon, top-left</p>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative" style="min-height: 80px;">
                <TabRibbon Color="TabColors.Green" Bookmark="true" Icon="@TabIcons.Outline.Award" />
                <div class="card-body">
                    <p class="text-muted small mb-0">Bookmark icon ribbon</p>
                </div>
            </div>
        </div>
    </div>
</ComponentDemo>

<ComponentDemo
    Id="ribbon-in-card"
    Title="Ribbon Inside a Card"
    Description="A practical example of ribbons used inside cards to highlight products or featured items."
    SourceCode="@_ribbonCardCode">
    <div class="row row-cards">
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative">
                <TabRibbon Color="TabColors.Red" Bookmark="true">SALE</TabRibbon>
                <div class="card-body">
                    <h4 class="card-title">Product Name</h4>
                    <p class="text-muted">A short product description goes here.</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h3 mb-0">$29.99</span>
                        <button class="btn btn-primary btn-sm">Buy Now</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative">
                <TabRibbon Color="TabColors.Green" Position="RibbonPosition.TopStart">NEW</TabRibbon>
                <div class="card-body">
                    <h4 class="card-title">New Arrival</h4>
                    <p class="text-muted">Just added to our collection.</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h3 mb-0">$49.99</span>
                        <button class="btn btn-success btn-sm">View</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-sm-6 col-lg-4">
            <div class="card position-relative">
                <TabRibbon Color="TabColors.Yellow" Icon="@TabIcons.Filled.Star" Bookmark="true" />
                <div class="card-body">
                    <h4 class="card-title">Featured Item</h4>
                    <p class="text-muted">Our most popular product this month.</p>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="h3 mb-0">$19.99</span>
                        <button class="btn btn-warning btn-sm">Details</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</ComponentDemo>

