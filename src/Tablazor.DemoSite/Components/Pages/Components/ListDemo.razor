    private record NotifItem(string Title, string Subtitle, string Icon, TabColors IconColor, string Time);
    private record TeamMember(string Name, string Role, TabColors AvatarColor, string Initials, bool IsActive);
    private record TaskItem(string Title, string Description, TabColors Priority, string PriorityLabel, string DueDate);
    private record EmailItem(string Sender, string SenderInitials, string Subject, string Time, bool HasAttachment);
    private record Contact(string Name, string Email, string Initials, TabColors Color);
    private record SettingItem(string Name, string Description, string Icon, TabColors IconColor, bool Enabled);

    private static readonly BasicItem[] _emptyBasicItems = [];
    private string _bulkMessage = string.Empty;
    private readonly List<string> _clickLog = [];

    private readonly List<BasicItem> _basicItems =
    [
        new("System Update Available", "Version 2.4.1 is ready to install"),
        new("Scheduled Maintenance Tonight", "Services will be offline 2–4 AM UTC"),
        new("Password Expires in 7 Days", "Update your credentials before the deadline")
