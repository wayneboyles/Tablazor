@page "/components/list"
@rendermode InteractiveServer
@using Tablazor.Icons

<SetTabPageHeader Title="List" Subtitle="A generic data-driven list with configurable avatar, icon, title, subtitle, and right-side slots. Supports row selection and bulk actions."></SetTabPageHeader>

<ComponentDemo Id="list-basic" Title="Basic" Description="Simple list with title and subtitle. Use TitleContent and SubtitleContent to define what each slot renders." SourceCode="@_basicCode">
    <TabList Items="@_basicItems" Title="Recent Updates">
        <TitleContent Context="item">@item.Title</TitleContent>
        <SubtitleContent Context="item">@item.Subtitle</SubtitleContent>
    </TabList>
</ComponentDemo>

<ComponentDemo Id="list-avatars" Title="With Avatars" Description="Add AvatarContent to render an avatar or initials on the left of each row." SourceCode="@_avatarsCode">
    <TabList Items="@_teamMembers" Title="Team Members">
        <AvatarContent Context="member">
            <TabAvatar Color="@member.AvatarColor">@member.Initials</TabAvatar>
        </AvatarContent>
        <TitleContent Context="member">@member.Name</TitleContent>
        <SubtitleContent Context="member">@member.Role</SubtitleContent>
        <RightContent Context="member">
            <TabBadge Color="@(member.IsActive ? TabColors.Success : TabColors.Secondary)">
                @(member.IsActive ? "Active" : "Away")
            </TabBadge>
        </RightContent>
    </TabList>
</ComponentDemo>

<ComponentDemo Id="list-icons" Title="With Icons" Description="Use AvatarContent to wrap a TabIcon in a coloured avatar for status-style lists." SourceCode="@_iconsCode">
    <TabList Items="@_notifications" Title="Notifications">
        <AvatarContent Context="notif">
            <span class="avatar bg-@(notif.IconColor.GetCssClassName())-lt">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="@notif.Icon" />
                </svg>
            </span>
        </AvatarContent>
        <TitleContent Context="notif">@notif.Title</TitleContent>
        <SubtitleContent Context="notif">@notif.Subtitle</SubtitleContent>
        <RightContent Context="notif">
            <span class="text-muted small">@notif.Time</span>
        </RightContent>
    </TabList>
</ComponentDemo>

<ComponentDemo Id="list-right-content" Title="Right Content" Description="Use RightContent to add metadata, badges, or actions on the trailing edge of each row." SourceCode="@_rightContentCode">
    <TabList Items="@_tasks" Title="Tasks">
        <TitleContent Context="task">@task.Title</TitleContent>
        <SubtitleContent Context="task">@task.Description</SubtitleContent>
        <RightContent Context="task">
            <div class="d-flex flex-column align-items-end gap-1">
                <TabBadge Color="@task.Priority">@task.PriorityLabel</TabBadge>
                <span class="text-muted small">Due @task.DueDate</span>
            </div>
        </RightContent>
    </TabList>
</ComponentDemo>

<ComponentDemo Id="list-selectable" Title="Selectable with Bulk Actions" Description="Set Selectable to show checkboxes. Add BulkActions to render action buttons in the header when rows are selected." SourceCode="@_selectableCode">
    <TabList Items="@_emails" Title="Inbox" Selectable="true">
        <BulkActions Context="selected">
            <TabButton Color="TabColors.Danger" Size="ButtonSize.Small" OnClick="DeleteSelected">Delete</TabButton>
            <TabButton Color="TabColors.Secondary" Size="ButtonSize.Small" OnClick="MarkAsRead" CssClass="ms-2">Mark as Read</TabButton>
        </BulkActions>
        <AvatarContent Context="email">
            <span class="avatar">@email.SenderInitials</span>
        </AvatarContent>
        <TitleContent Context="email">
            <strong>@email.Sender</strong>
        </TitleContent>
        <SubtitleContent Context="email">@email.Subject</SubtitleContent>
        <RightContent Context="email">
            <div class="d-flex align-items-center gap-2">
                @if (email.HasAttachment)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-muted">
                        <path d="@TabIcons.Filled.Pin" />
                    </svg>
                }
                <span class="text-muted small">@email.Time</span>
            </div>
        </RightContent>
    </TabList>
    @if (!string.IsNullOrEmpty(_bulkMessage))
    {
        <TabAlert Color="TabColors.Info" Message="@_bulkMessage" CssClass="mt-3" OnClose="ClearBulkMessage" />
    }
</ComponentDemo>

<ComponentDemo Id="list-click" Title="Item Click Events" Description="Set OnItemClick to handle row clicks. Items render with list-group-item-action styling automatically." SourceCode="@_clickCode">
    <TabList Items="@_contacts" Title="Contacts" OnItemClick="@((Contact c) => HandleContactClick(c))">
        <AvatarContent Context="contact">
            <TabAvatar Color="@contact.Color">@contact.Initials</TabAvatar>
        </AvatarContent>
        <TitleContent Context="contact">@contact.Name</TitleContent>
        <SubtitleContent Context="contact">@contact.Email</SubtitleContent>
        <RightContent Context="contact">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" class="text-muted">
                <path d="@TabIcons.Filled.ChevronRight" />
            </svg>
        </RightContent>
    </TabList>
    @if (_clickLog.Count > 0)
    {
        <div class="mt-3">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <small class="text-muted fw-medium">Click log</small>
                <button class="btn btn-sm btn-ghost-secondary" @onclick="ClearClickLog">Clear</button>
            </div>
            <div class="list-group list-group-flush">
                @foreach (var entry in _clickLog)
                {
                    <div class="list-group-item py-1 px-2 small">@entry</div>
                }
            </div>
        </div>
    }
</ComponentDemo>

<ComponentDemo Id="list-empty" Title="Empty State" Description="EmptyText sets a default message. Use EmptyContent for a custom empty-state template." SourceCode="@_emptyCode">
    <div class="row g-3">
        <div class="col-md-6">
            <TabList Items="@_emptyBasicItems" Title="Default empty" EmptyText="No updates yet.">
                <TitleContent Context="item">@item.Title</TitleContent>
            </TabList>
        </div>
        <div class="col-md-6">
            <TabList Items="@_emptyBasicItems" Title="Custom empty">
                <EmptyContent>
                    <div class="text-center py-5">
                        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="text-muted mb-2">
                            <path d="@TabIcons.Filled.MailOpened" />
                        </svg>
                        <h4 class="text-muted mt-2">Inbox zero!</h4>
                        <p class="text-muted">No messages to show.</p>
                    </div>
                </EmptyContent>
                <TitleContent Context="item">@item.Title</TitleContent>
            </TabList>
        </div>
    </div>
</ComponentDemo>

<ComponentDemo Id="list-no-card" Title="Without Card" Description="Set WrapInCard to false and Flush to false for a standalone bordered list." SourceCode="@_noCardCode">
    <TabList Items="@_settings" WrapInCard="false" Flush="false">
        <AvatarContent Context="setting">
            <span class="avatar bg-@(setting.IconColor.GetCssClassName())-lt">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                    <path d="@setting.Icon" />
                </svg>
            </span>
        </AvatarContent>
        <TitleContent Context="setting">@setting.Name</TitleContent>
        <SubtitleContent Context="setting">@setting.Description</SubtitleContent>
        <RightContent Context="setting">
            <label class="form-check form-switch m-0">
                <input class="form-check-input" type="checkbox" checked="@setting.Enabled" />
            </label>
        </RightContent>
    </TabList>
</ComponentDemo>

@code {
