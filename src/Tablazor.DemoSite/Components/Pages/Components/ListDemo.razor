        new("Alice Johnson", "Product Manager", TabColors.Primary, "AJ", true),
        new("Bob Smith", "Senior Developer", TabColors.Success, "BS", true),
        new("Carol White", "UI/UX Designer", TabColors.Purple, "CW", false),
        new("David Brown", "DevOps Engineer", TabColors.Cyan, "DB", true)
    ];

    private readonly List<NotifItem> _notifications =
    [
        new("Deployment Successful", "Production deploy completed", TabIcons.Filled.CircleCheck, TabColors.Success, "10m ago"),
        new("High CPU Usage", "Server load above 85%", TabIcons.Filled.AlertCircle, TabColors.Warning, "25m ago"),
        new("Database Backup Failed", "Check connection settings", TabIcons.Filled.AlertTriangle, TabColors.Danger, "1h ago"),
        new("New User Registered", "Welcome email sent", TabIcons.Filled.Mail, TabColors.Blue, "3h ago")
    ];

    private readonly List<TaskItem> _tasks =
    [
        new("Fix login bug", "Users unable to authenticate via SSO", TabColors.Danger, "Critical", "Today"),
        new("Update documentation", "Add API reference examples", TabColors.Warning, "Medium", "Tomorrow"),
        new("Code review", "Review PR #347 — new auth flow", TabColors.Info, "Normal", "Friday"),
        new("Team meeting", "Weekly standup — 15 min", TabColors.Secondary, "Low", "Monday")
    ];

    private readonly List<EmailItem> _emails =
    [
        new("Sarah Connor", "SC", "Re: Project Timeline Update", "9:15 AM", true),
        new("John Connor", "JC", "Budget Proposal Q2", "Yesterday", false),
        new("Kyle Reese", "KR", "Team Building Event Next Week", "2 days ago", false),
        new("Miles Dyson", "MD", "Security Patch Release Notes", "3 days ago", true)
    ];

    private readonly List<Contact> _contacts =
    [
        new("Emma Watson", "emma.watson@example.com", "EW", TabColors.Pink),
        new("Michael Scott", "michael.scott@example.com", "MS", TabColors.Orange),
        new("Leslie Knope", "leslie.knope@example.com", "LK", TabColors.Yellow),
        new("Ron Swanson", "ron.swanson@example.com", "RS", TabColors.Teal)
    ];

    private readonly List<SettingItem> _settings =
    [
        new("Email Notifications", "Receive email alerts for new activity", TabIcons.Filled.Mail, TabColors.Blue, true),
        new("Two-Factor Authentication", "Add an extra layer of account security", TabIcons.Filled.Shield, TabColors.Green, false),
        new("Dark Mode", "Use dark theme across the application", TabIcons.Filled.Moon, TabColors.Purple, true),
        new("Auto-Save", "Automatically save your work every 5 minutes", TabIcons.Filled.DeviceFloppy, TabColors.Orange, true)
    ];

    private void DeleteSelected() => _bulkMessage = "Delete action triggered.";
    private void MarkAsRead() => _bulkMessage = "Mark as read action triggered.";
    private void ClearBulkMessage() => _bulkMessage = string.Empty;

    private void HandleContactClick(Contact contact)
    {
        _clickLog.Insert(0, $"Clicked: {contact.Name} at {DateTime.Now:HH:mm:ss}");
        if (_clickLog.Count > 8) _clickLog.RemoveAt(_clickLog.Count - 1);
    }

    private void ClearClickLog() => _clickLog.Clear();

    // ── Code strings ─────────────────────────────────────────────────────────

    private const string _basicCode = """
        <TabList Items="@items" Title="Recent Updates">
            <TitleContent Context="item">@item.Title</TitleContent>
            <SubtitleContent Context="item">@item.Subtitle</SubtitleContent>
        </TabList>
        """;

    private const string _avatarsCode = """
        <TabList Items="@teamMembers" Title="Team Members">
            <AvatarContent Context="member">
                <TabAvatar Color="@member.AvatarColor">@member.Initials</TabAvatar>
            </AvatarContent>
            <TitleContent Context="member">@member.Name</TitleContent>
            <SubtitleContent Context="member">@member.Role</SubtitleContent>
            <RightContent Context="member">
                <TabBadge Color="@(member.IsActive ? TabColors.Success : TabColors.Secondary)">
