@page "/components/table"
@rendermode InteractiveServer
@using Tablazor.Icons

<PageTitle>Table - Tablazor</PageTitle>

<div class="page-header mb-4">
    <h1 class="page-title">Table</h1>
    <p class="text-muted">
        Data tables with sortable columns, row selection, row actions, icons, avatars, and image thumbnails.
    </p>
</div>

<ComponentDemo Id="table-user-directory" Title="User Directory" Description="A realistic user table combining AvatarField, IconField, badge status, and row actions in one view." SourceCode="@_userDirectoryCode">
    <TabTable Items="_users" Title="Team Members">
        <ColumnDefinitions>
            <TabTableColumn TItem="UserRow" Title="" AvatarField="u => u.AvatarUrl" AvatarColor="TabColors.Primary" Width="48px" />
            <TabTableColumn TItem="UserRow" Title="Name" Sortable="true" SortField="u => u.Name">
                <CellTemplate Context="user">
                    <div class="d-flex flex-column">
                        <span class="fw-medium">@user.Name</span>
                        <span class="text-muted small">@user.Email</span>
                    </div>
                </CellTemplate>
            </TabTableColumn>
            <TabTableColumn TItem="UserRow" Title="Role" IconField="u => u.RoleIcon" Width="40px" Align="TableColumnAlign.Center" />
            <TabTableColumn TItem="UserRow" Title="" Field="u => u.Role" />
            <TabTableColumn TItem="UserRow" Title="Status">
                <CellTemplate Context="user">
                    @if (user.IsActive)
                    {
                        <TabBadge Color="TabColors.Success">Active</TabBadge>
                    }
                    else
                    {
                        <TabBadge Color="TabColors.Danger">Inactive</TabBadge>
                    }
                </CellTemplate>
            </TabTableColumn>
            <TabTableColumn TItem="UserRow" Title="Joined" Field="u => FormatJoined(u)" Align="TableColumnAlign.End" />
        </ColumnDefinitions>
        <RowActions Context="user">
            <div class="btn-list flex-nowrap">
                <button class="btn btn-sm" @onclick="() => OnEditUser(user)">
                    <TabIcon Icon="@TabIcons.Filled.Pencil" Size="16" />
                </button>
                <button class="btn btn-sm btn-danger" @onclick="() => OnDeleteUser(user)">
                    <TabIcon Icon="@TabIcons.Filled.CircleX" Size="16" />
                </button>
            </div>
        </RowActions>
    </TabTable>
    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="alert alert-info mt-3">@_message</div>
    }
</ComponentDemo>

<ComponentDemo Id="table-avatar-name" Title="Avatar with Name (CellTemplate)" Description="Combine TabAvatar and a name/subtitle in a single cell using CellTemplate for a rich contact-list look." SourceCode="@_avatarNameCode">
    <TabTable Items="_users" Title="Contacts" Hover="true">
        <ColumnDefinitions>
            <TabTableColumn TItem="UserRow" Title="User">
                <CellTemplate Context="user">
                    <div class="d-flex align-items-center gap-3">
                        @if (!string.IsNullOrEmpty(user.AvatarUrl))
                        {
                            <TabAvatar ImageUrl="@user.AvatarUrl" />
                        }
                        else
                        {
                            <TabAvatar Color="TabColors.Primary" />
                        }
                        <div>
                            <div class="fw-medium">@user.Name</div>
                            <div class="text-muted small">@user.Email</div>
                        </div>
                    </div>
                </CellTemplate>
            </TabTableColumn>
            <TabTableColumn TItem="UserRow" Title="Role" Field="u => u.Role" />
            <TabTableColumn TItem="UserRow" Title="Joined" Field="u => FormatJoined(u)" Align="TableColumnAlign.End" />
        </ColumnDefinitions>
    </TabTable>
</ComponentDemo>

<ComponentDemo Id="table-icon-field" Title="IconField — TabIcons in Columns" Description="Use IconField with SVG path data from TabIcons to render inline icons. Each row can return a different icon based on data." SourceCode="@_iconFieldCode">
    <TabTable Items="_files" Title="Files">
        <ColumnDefinitions>
            <TabTableColumn TItem="FileRow" Title="" IconField="f => f.TypeIcon" Width="40px" Align="TableColumnAlign.Center" />
            <TabTableColumn TItem="FileRow" Title="Name" Field="f => f.Name" Sortable="true" />
            <TabTableColumn TItem="FileRow" Title="Type" Field="f => f.Type" />
            <TabTableColumn TItem="FileRow" Title="Size" Field="f => f.Size" Align="TableColumnAlign.End" />
            <TabTableColumn TItem="FileRow" Title="Modified" Field="f => f.Modified.ToShortDateString()" Align="TableColumnAlign.End" />
        </ColumnDefinitions>
    </TabTable>
</ComponentDemo>

<ComponentDemo Id="table-image-field" Title="ImageField — Photo Thumbnails" Description="Use ImageField to render a plain img element in a column — ideal for product photos, thumbnails, or any external image URL." SourceCode="@_imageFieldCode">
    <TabTable Items="_products" Title="Products" Hover="true">
        <ColumnDefinitions>
            <TabTableColumn TItem="ProductRow" Title="" ImageField="p => p.ImageUrl" ImageAlt="product" ImageClass="rounded" Width="56px" />
            <TabTableColumn TItem="ProductRow" Title="Product" Field="p => p.Name" Sortable="true" />
            <TabTableColumn TItem="ProductRow" Title="Category" Field="p => p.Category" />
            <TabTableColumn TItem="ProductRow" Title="Price" Field="p => FormatPrice(p)" Align="TableColumnAlign.End" Sortable="true" />
            <TabTableColumn TItem="ProductRow" Title="Stock">
                <CellTemplate Context="product">
                    @if (product.InStock)
                    {
                        <TabBadge Color="TabColors.Success">In Stock</TabBadge>
                    }
                    else
                    {
                        <TabBadge Color="TabColors.Secondary">Out of Stock</TabBadge>
                    }
                </CellTemplate>
            </TabTableColumn>
        </ColumnDefinitions>
    </TabTable>
</ComponentDemo>

<ComponentDemo Id="basic-table" Title="Basic Table" Description="A simple table with column definitions and sortable columns." SourceCode="@_basicTableCode">
    <TabTable Items="_users" Title="Users">
        <ColumnDefinitions>
            <TabTableColumn TItem="UserRow" Title="Name" Field="u => u.Name" Sortable="true" />
            <TabTableColumn TItem="UserRow" Title="Email" Field="u => u.Email" />
            <TabTableColumn TItem="UserRow" Title="Role" Field="u => u.Role" />
            <TabTableColumn TItem="UserRow" Title="Joined" Field="u => u.Joined.ToShortDateString()" Align="TableColumnAlign.End" />
        </ColumnDefinitions>
    </TabTable>
</ComponentDemo>

<ComponentDemo Id="table-selectable" Title="Row Selection" Description="Enable checkboxes with Selectable. Use OnSelectionChanged to react to selection changes." SourceCode="@_selectableTableCode">
    <TabTable TItem="UserRow" Items="_users" Title="Select Users" Selectable="true" OnSelectionChanged="selected => OnSelectionChanged(selected)">
        <ColumnDefinitions>
            <TabTableColumn TItem="UserRow" Title="" AvatarField="u => u.AvatarUrl" AvatarColor="TabColors.Primary" Width="40px" />
            <TabTableColumn TItem="UserRow" Title="Name" Field="u => u.Name" Sortable="true" />
            <TabTableColumn TItem="UserRow" Title="Email" Field="u => u.Email" />
            <TabTableColumn TItem="UserRow" Title="Role" Field="u => u.Role" />
        </ColumnDefinitions>
    </TabTable>
    <div class="mt-3 text-muted">
        Selected: @_selectedCount user(s)
    </div>
</ComponentDemo>

<ComponentDemo Id="table-striped" Title="Striped &amp; Compact" Description="Use Striped for alternating row shading and Small for compact padding." SourceCode="@_stripedTableCode">
    <TabTable Items="_users" Title="Striped Table" Striped="true" Small="true">
        <ColumnDefinitions>
            <TabTableColumn TItem="UserRow" Title="Name" Field="u => u.Name" />
            <TabTableColumn TItem="UserRow" Title="Email" Field="u => u.Email" />
            <TabTableColumn TItem="UserRow" Title="Role" Field="u => u.Role" />
            <TabTableColumn TItem="UserRow" Title="Joined" Field="u => u.Joined.ToShortDateString()" Align="TableColumnAlign.End" />
        </ColumnDefinitions>
    </TabTable>
</ComponentDemo>

<ComponentDemo Id="table-empty" Title="Empty State" Description="When Items is empty, a configurable message is shown." SourceCode="@_emptyTableCode">
    <TabTable Items="_emptyList" Title="No Results" EmptyText="No users found matching your search.">
        <ColumnDefinitions>
            <TabTableColumn TItem="UserRow" Title="Name" Field="u => u.Name" />
            <TabTableColumn TItem="UserRow" Title="Email" Field="u => u.Email" />
        </ColumnDefinitions>
    </TabTable>
</ComponentDemo>

<ComponentDemo Id="table-custom-header" Title="Custom Header with Search" Description="Use HeaderContent to render a fully custom card header with search or filter controls." SourceCode="@_customHeaderCode">
    <TabTable Items="_filteredUsers" WrapInCard="true">
        <HeaderContent>
            <div class="card-title">Users</div>
            <div class="card-options">
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control" placeholder="Search..." @oninput="OnSearchInput" value="@_searchText" />
                </div>
            </div>
        </HeaderContent>
        <ColumnDefinitions>
            <TabTableColumn TItem="UserRow" Title="" AvatarField="u => u.AvatarUrl" AvatarColor="TabColors.Primary" Width="40px" />
            <TabTableColumn TItem="UserRow" Title="Name" Field="u => u.Name" Sortable="true" />
            <TabTableColumn TItem="UserRow" Title="Email" Field="u => u.Email" />
            <TabTableColumn TItem="UserRow" Title="Role" Field="u => u.Role" />
        </ColumnDefinitions>
    </TabTable>
</ComponentDemo>

@code {
    private string _message = string.Empty;
    private int _selectedCount;
    private string _searchText = string.Empty;
    private IEnumerable<UserRow> _filteredUsers = [];

    private static readonly List<UserRow> _users =
    [
        new("Alice Johnson",  "alice@example.com",  "Admin",  new DateTime(2022, 3, 15),  true,  TabIcons.Filled.Shield, "https://i.pravatar.cc/40?img=47"),
        new("Bob Smith",      "bob@example.com",    "Editor", new DateTime(2023, 7, 1),   true,  TabIcons.Filled.Pencil, "https://i.pravatar.cc/40?img=53"),
        new("Carol Williams", "carol@example.com",  "Viewer", new DateTime(2021, 11, 20), false, TabIcons.Filled.Eye,    "https://i.pravatar.cc/40?img=49"),
        new("David Brown",    "david@example.com",  "Editor", new DateTime(2024, 1, 9),   true,  TabIcons.Filled.Pencil, "https://i.pravatar.cc/40?img=57"),
        new("Eva Davis",      "eva@example.com",    "Admin",  new DateTime(2023, 5, 14),  false, TabIcons.Filled.Shield, "https://i.pravatar.cc/40?img=44"),
    ];

    private static readonly List<FileRow> _files =
    [
        new("Annual Report.pdf",   "PDF",        TabIcons.Filled.FileDescription, "2.4 MB",  new DateTime(2025, 3, 10)),
        new("Budget 2025.xlsx",    "Excel",      TabIcons.Filled.FileAnalytics,   "840 KB",  new DateTime(2025, 3, 18)),
        new("Presentation.pptx",  "PowerPoint", TabIcons.Filled.Presentation,    "5.1 MB",  new DateTime(2025, 2, 27)),
        new("Logo.png",            "Image",      TabIcons.Filled.Camera,          "320 KB",  new DateTime(2025, 1, 14)),
        new("README.md",           "Markdown",   TabIcons.Filled.FileText,        "12 KB",   new DateTime(2025, 3, 20)),
        new("Archive.zip",         "Archive",    TabIcons.Outline.Archive,        "18.7 MB", new DateTime(2025, 2, 5)),
    ];

    private static readonly List<ProductRow> _products =
    [
        new("Wireless Headphones", "Electronics", 89.99m,  true,  "https://picsum.photos/seed/headphones/56/40"),
        new("Running Shoes",       "Footwear",    129.95m, true,  "https://picsum.photos/seed/shoes/56/40"),
        new("Coffee Maker",        "Appliances",  59.00m,  false, "https://picsum.photos/seed/coffee/56/40"),
        new("Backpack",            "Bags",        45.50m,  true,  "https://picsum.photos/seed/backpack/56/40"),
        new("Desk Lamp",           "Furniture",   34.99m,  true,  "https://picsum.photos/seed/lamp/56/40"),
    ];

    private static readonly List<UserRow> _emptyList = [];

    protected override void OnInitialized() => _filteredUsers = _users;

    private static string FormatJoined(UserRow u) => u.Joined.ToString("MMM d, yyyy");
    private static string FormatPrice(ProductRow p) => p.Price.ToString("C");

    private void OnEditUser(UserRow u) => _message = "Edit: " + u.Name;
    private void OnDeleteUser(UserRow u) => _message = "Delete: " + u.Name;

    private void OnSelectionChanged(IEnumerable<UserRow> selected) => _selectedCount = selected.Count();

    private void OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? string.Empty;
        _filteredUsers = string.IsNullOrWhiteSpace(_searchText)
            ? _users
            : _users.Where(u =>
                u.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                u.Email.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ||
                u.Role.Contains(_searchText, StringComparison.OrdinalIgnoreCase));
    }

    public record UserRow(string Name, string Email, string Role, DateTime Joined, bool IsActive,
        string? RoleIcon = null, string? AvatarUrl = null);

    public record FileRow(string Name, string Type, string? TypeIcon, string Size, DateTime Modified);

    public record ProductRow(string Name, string Category, decimal Price, bool InStock, string? ImageUrl);

    // ── Code strings ─────────────────────────────────────────────────────────

    private const string _userDirectoryCode = """
        @using Tablazor.Icons

        <TabTable Items="_users" Title="Team Members">
