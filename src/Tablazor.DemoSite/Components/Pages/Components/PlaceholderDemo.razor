@page "/components/placeholder"
@rendermode InteractiveServer

<SetTabPageHeader Title="Placeholder" Subtitle="Placeholders are purely CSS-based skeleton loaders used to indicate that content is loading. They require no JavaScript and are fully accessible when combined with aria-hidden."></SetTabPageHeader>

<ComponentDemo Id="basic-placeholder" Title="Basic Placeholder" Description="Individual placeholder spans at different column widths." SourceCode="@_basicCode">
    <TabPlaceholderContainer Animation="PlaceholderAnimation.Glow">
        <TabPlaceholder Columns="12" />
        <TabPlaceholder Columns="8" />
        <TabPlaceholder Columns="6" />
        <TabPlaceholder Columns="4" />
        <TabPlaceholder Columns="2" />
    </TabPlaceholderContainer>
</ComponentDemo>

<ComponentDemo Id="placeholder-sizes" Title="Sizes" Description="Placeholders are available in four sizes: ExtraSmall, Small, Default, and Large." SourceCode="@_sizesCode">
    <TabPlaceholderContainer Animation="PlaceholderAnimation.Glow">
        <TabPlaceholder Columns="12" Size="PlaceholderSize.ExtraSmall" />
        <TabPlaceholder Columns="12" Size="PlaceholderSize.Small" />
        <TabPlaceholder Columns="12" />
        <TabPlaceholder Columns="12" Size="PlaceholderSize.Large" />
    </TabPlaceholderContainer>
</ComponentDemo>

<ComponentDemo Id="placeholder-colors" Title="Colors" Description="Apply background colors using the Color parameter." SourceCode="@_colorsCode">
    <TabPlaceholderContainer>
        <TabPlaceholder Columns="12" Color="TabColors.Primary" />
        <TabPlaceholder Columns="12" Color="TabColors.Success" />
        <TabPlaceholder Columns="12" Color="TabColors.Danger" />
        <TabPlaceholder Columns="12" Color="TabColors.Warning" />
        <TabPlaceholder Columns="12" Color="TabColors.Info" />
    </TabPlaceholderContainer>
</ComponentDemo>

<ComponentDemo Id="placeholder-animations" Title="Animations" Description="Use Glow for a pulsing opacity effect or Wave for a shimmer sweep. The animation class is applied to the container, not the individual spans." SourceCode="@_animationsCode">
    <div class="row">
        <div class="col-6">
            <p class="text-muted mb-1"><strong>Glow</strong></p>
            <TabPlaceholderContainer Animation="PlaceholderAnimation.Glow">
                <TabPlaceholder Columns="12" />
                <TabPlaceholder Columns="8" />
                <TabPlaceholder Columns="10" />
            </TabPlaceholderContainer>
        </div>
        <div class="col-6">
            <p class="text-muted mb-1"><strong>Wave</strong></p>
            <TabPlaceholderContainer Animation="PlaceholderAnimation.Wave">
                <TabPlaceholder Columns="12" />
                <TabPlaceholder Columns="8" />
                <TabPlaceholder Columns="10" />
            </TabPlaceholderContainer>
        </div>
    </div>
</ComponentDemo>

<ComponentDemo Id="placeholder-skeleton-card" Title="Skeleton Card" Description="A realistic skeleton loader that mimics a loading card with a title, body text, and a disabled button placeholder." SourceCode="@_skeletonCardCode">
    <div class="card" style="max-width: 400px;">
        <div class="card-body">
            <TabPlaceholderContainer Tag="p" Animation="PlaceholderAnimation.Glow" CssClass="card-title h5">
                <TabPlaceholder Columns="6" />
            </TabPlaceholderContainer>
            <TabPlaceholderContainer Tag="p" Animation="PlaceholderAnimation.Glow" CssClass="card-text">
                <TabPlaceholder Columns="7" />
                <TabPlaceholder Columns="4" />
                <TabPlaceholder Columns="8" />
                <TabPlaceholder Columns="5" />
            </TabPlaceholderContainer>
            <TabPlaceholder Columns="6" Color="TabColors.Primary" CssClass="btn btn-primary disabled" />
        </div>
    </div>
</ComponentDemo>

